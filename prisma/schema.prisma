generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String          @id @default(uuid())
  email              String          @unique
  passwordHash       String
  createdAt          DateTime        @default(now())
  selectedProgramId  String?
  selectedSemesterId String?
  subjects           Subject[]
  collaborations     Collaboration[]
}

model Subject {
  id            String          @id
  name          String
  threshold     Float
  semesterId    String
  submissionUrl String?
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deadlines     Deadline[]
  scores        Score[]
  collaborators Collaboration[] // Wer arbeitet hier noch mit?
}

model Deadline {
  id        String   @id
  title     String
  date      String
  time      String?
  urgency   Int      @default(3)
  completed Boolean
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Score {
  id        String  @id @default(uuid())
  weekId    String
  type      String
  value     String
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Collaboration {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  // NEU: Der Status der Einladung
  status    String  @default("PENDING")

  @@unique([userId, subjectId])
}